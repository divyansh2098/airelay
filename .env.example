# AI backend: gemini-cli or claude-cli
AIRELAY_BACKEND=gemini-cli

# Model ID (e.g., claude-sonnet-4-6)
AIRELAY_MODEL=claude-sonnet-4-6

# Fraction of context window before wrap-up (0.0 to 1.0)
AIRELAY_CONTEXT_THRESHOLD=0.7

# Hard turn cap per agent invocation
AIRELAY_MAX_TURNS=200

# Default run_bash timeout in milliseconds
AIRELAY_BASH_TIMEOUT_MS=300000

# Note: Underlying CLI tools (gemini, claude) might require their own keys
# e.g., ANTHROPIC_API_KEY for claude or GOOGLE_API_KEY for gemini
# These should be set in your environment if required by those tools.
